  "keyFeatures": [
    "Automatic SPIFFE ID issuance to workloads via X.509-SVIDs and JWT-SVIDs",
    "Node attestation for AWS, GCP, Azure, Kubernetes, TPM, SSH, and more",
    "Workload attestation via Kubernetes, Docker, Unix, and systemd",
    "Pluggable upstream CA integration (Vault, AWS PCA, GCP CAS, cert-manager)",
    "Federation across multiple trust domains",
    "Nested SPIRE topology for multi-cloud deployments",
    "High availability via shared datastore (PostgreSQL, MySQL)",
    "Envoy SDS integration for transparent mTLS",
    "Trust bundle publishing to S3, GCS, and Kubernetes ConfigMaps",
    "CNCF graduated project with production security audits"
  ],
  "publicApiSurface": [
    "SPIFFE Workload API (gRPC)",
    "SPIRE Server API (gRPC)",
    "spire-server entry create/update/delete/show",
    "spire-server agent list/ban/evict",
    "spire-server bundle show/set/refresh/list",
    "spire-server token generate",
    "spire-server federation create/refresh",
    "spire-server jwt mint",
    "spire-server x509 mint",
    "spire-agent api fetch x509",
    "spire-agent api fetch jwt",
    "Delegated Identity API"
  ]
